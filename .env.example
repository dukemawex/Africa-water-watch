# ============================================================
# AquaWatch Africa — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
# Connection URL for the PostGIS-enabled PostgreSQL database
DATABASE_URL=postgresql+asyncpg://aquawatch:changeme@db:5432/aquawatch

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── JWT Auth ─────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=your-super-secret-jwt-key-change-in-production
ALGORITHM=HS256
# Access token lifetime in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60
# Refresh token lifetime in days
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── OpenRouter AI ─────────────────────────────────────────────
# Get your free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_PRIMARY_MODEL=google/gemma-3-12b-it:free
OPENROUTER_FALLBACK_MODEL=meta-llama/llama-3.1-8b-instruct:free

# ── Sentinel Hub (Copernicus) ─────────────────────────────────
# Register at https://dataspace.copernicus.eu/
SENTINEL_HUB_CLIENT_ID=your-sentinel-hub-client-id
SENTINEL_HUB_CLIENT_SECRET=your-sentinel-hub-client-secret

# ── Africa's Talking SMS ──────────────────────────────────────
# Register at https://africastalking.com
AFRICAS_TALKING_API_KEY=your-africastalking-api-key
AFRICAS_TALKING_USERNAME=aquawatch
# Set to true to skip actual SMS sending during development
SMS_SANDBOX=true

# ── Internal API Security ────────────────────────────────────
# Key required to call /api/satellite/refresh
INTERNAL_API_KEY=your-internal-api-key

# ── CORS / Frontend ───────────────────────────────────────────
# URL of the frontend app (for CORS whitelist)
FRONTEND_URL=http://localhost:5173

# ── DigitalOcean Deployment ───────────────────────────────────
# DigitalOcean personal access token (used in GitHub Actions)
DO_ACCESS_TOKEN=your-digitalocean-access-token
# DigitalOcean App Platform app ID
DO_APP_ID=your-digitalocean-app-id
# DigitalOcean Container Registry name
DO_REGISTRY=your-do-registry-name

# ── PostgreSQL direct credentials (for docker-compose) ───────
POSTGRES_USER=aquawatch
POSTGRES_PASSWORD=changeme
POSTGRES_DB=aquawatch

# ── App Metadata ──────────────────────────────────────────────
APP_ENV=development
APP_VERSION=1.0.0
